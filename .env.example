# TestRail 連線設定
# 複製此檔案為 .env.local 並填入你的資訊

# TestRail 網址（不含結尾斜線）
TESTRAIL_BASE_URL=https://yourcompany.testrail.io
# 同上，供 client-side 圖片 proxy 使用（非敏感，可公開）
NEXT_PUBLIC_TESTRAIL_BASE_URL=https://yourcompany.testrail.io

# TestRail 登入 Email
TESTRAIL_EMAIL=your@email.com

# TestRail API Key（在 TestRail -> My Settings -> API Keys 產生）
TESTRAIL_API_KEY=your_api_key_here

# NextAuth — Google OAuth
# 產生 secret：openssl rand -base64 32
AUTH_SECRET=your_random_secret_here
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
